{
  "name": "altus-app",
  "version": "0.0.1",
  "private": true,
  "imports": {
    "#tools/*": "./src/tools/*",
    "#lib/*": "./src/lib/*",
    "#components/*": "./src/components/*"
  },
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "mac": "react-native run-macos",
    "lint": "eslint . --fix",
    "pretty": "prettier -u --write *",
    "start": "react-native start",
    "test": "npx tsx --test tests/unit/*.test.ts",
    "test:unit:single": "npx tsx --test",
    "test:bundle": "react-native bundle --platform macos --entry-file index.js --bundle-output /tmp/altus-bundle.js --dev false",
    "ts:check": "tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "3.1.1",
    "@types/events": "3.0.3",
    "events": "3.3.0",
    "react": "19.1.4",
    "react-native": "0.81.6",
    "react-native-macos": "0.81.7",
    "react-native-webrtc": "file:../../packages/react-native-webrtc"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@eslint/js": "^9.39.4",
    "@react-native-community/cli": "20.0.0",
    "@react-native-community/cli-platform-android": "20.0.0",
    "@react-native-community/cli-platform-ios": "20.0.0",
    "@react-native/babel-preset": "0.81.6",
    "@react-native/metro-config": "0.81.6",
    "@types/react": "^19.1.4",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "babel-plugin-module-resolver": "^5.0.3",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "prettier": "3.8.4",
    "tsx": "4.22.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.61.1"
  },
  "engines": {
    "node": ">=24"
  }
}
